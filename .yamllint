extends: default
rules:
  document-start: disable
  line-length:
    max: 160
    level: warning
  truthy:
    # Allow 'on' and 'off' for GitHub Actions workflow triggers
    allowed-values: ["true", "false", "yes", "no", "on", "off"]
    check-keys: false
  comments:
    # Require 2 spaces before inline comments — the goneat/yamllint canonical,
    # matched by `pad_line_comments: 2` in .yamlfmt so both fmt paths agree.
    min-spaces-from-content: 2
  indentation:
    spaces: 2
    indent-sequences: consistent

ignore:
  - node_modules/
  - .git/
  - .plans/
  - bin/
