{
  "name": "@3leaps/crucible",
  "version": "0.1.19",
  "private": true,
  "description": "Lightweight standards and specifications for 3leaps open source projects",
  "type": "module",
  "scripts": {
    "fmt": "prettier --write '**/*.md' '**/*.json' --ignore-path .gitignore",
