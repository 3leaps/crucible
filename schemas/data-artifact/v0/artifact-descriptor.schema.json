{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "contract:data-artifact/v0/artifact-descriptor.schema.json",
  "title": "Portable Data Artifact Descriptor",
  "description": "Structural schema companion for contract: data-artifact/v0. The prose standard remains normative; export-gate behavior is enforced by consumers.",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "capabilities",
    "artifact_id",
    "lifecycle",
    "producer",
    "grains",
    "representations",
    "protection"
  ],
  "properties": {
    "capabilities": {
      "type": "array",
      "description": "Host-less capability tokens. Must include the exact opaque data-artifact contract token.",
      "items": { "type": "string" },
      "contains": { "const": "contract: data-artifact/v0" },
      "minItems": 1,
      "uniqueItems": true
    },
    "artifact_id": {
      "type": "string",
      "description": "Artifact identity. UUID URNs are recommended for generated artifacts.",
      "minLength": 1
    },
    "lifecycle": {
      "enum": ["draft", "building", "complete", "partial", "incomplete", "retired"]
    },
    "producer": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "version", "profile"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "version": { "type": "string", "minLength": 1 },
        "profile": { "type": "string", "minLength": 1 },
        "run_id": { "type": "string", "minLength": 1 }
      }
    },
    "grains": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/grain" }
    },
    "representations": {
      "type": "array",
      "minItems": 1,
      "items": { "$ref": "#/$defs/representation" }
    },
    "field_catalogs": {
      "type": "array",
      "description": "Embedded field catalogs for portable fixtures and small artifacts. Larger artifacts may use refs from grains/representations instead.",
      "items": { "$ref": "#/$defs/fieldCatalog" }
    },
    "provenance": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "job_ref": { "type": "string", "minLength": 1 },
        "source_refs": {
          "type": "array",
          "items": {
            "type": "object",
            "additionalProperties": false,
            "required": ["kind", "ref"],
            "properties": {
              "kind": { "type": "string", "minLength": 1 },
              "ref": { "type": "string", "minLength": 1 }
            }
          }
        }
      }
    },
    "accounting": {
      "type": "object",
      "additionalProperties": true
    },
    "protection": {
      "type": "object",
      "additionalProperties": false,
      "required": ["default_action"],
      "properties": {
        "default_action": { "const": "block_export" },
        "default_export_class": { "enum": ["public", "internal", "controlled", "restricted"] },
        "profile_ref": { "type": "string", "minLength": 1 }
      }
    }
  },
  "$defs": {
    "profileExtensionToken": {
      "type": "string",
      "description": "Profile-qualified extension token. Base vocabulary terms omit slashes; extensions include a profile namespace such as example.profile/v0.",
      "pattern": "^[A-Za-z0-9][A-Za-z0-9._-]*/[A-Za-z0-9][A-Za-z0-9._/-]*$"
    },
    "grain": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "kind", "record_kind", "field_catalog_ref"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "kind": {
          "anyOf": [
            {
              "enum": [
                "record_stream",
                "object_index",
                "aggregation",
                "reference_table",
                "projection"
              ]
            },
            { "$ref": "#/$defs/profileExtensionToken" }
          ]
        },
        "record_kind": { "type": "string", "minLength": 1 },
        "row_count": { "type": "integer", "minimum": 0 },
        "primary_keys": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "semantic_order": { "type": "string", "minLength": 1 },
        "field_catalog_ref": { "type": "string", "minLength": 1 },
        "provenance_ref": { "type": "string", "minLength": 1 },
        "accounting_ref": { "type": "string", "minLength": 1 },
        "disclosure_control": { "$ref": "#/$defs/disclosureControl" }
      }
    },
    "representation": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "id",
        "role",
        "format",
        "uri",
        "read_path",
        "protection_enforceable_granularity"
      ],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "grain": { "type": "string", "minLength": 1 },
        "role": {
          "anyOf": [
            {
              "enum": [
                "audit_stream",
                "tabular_projection",
                "analytics_scan",
                "object_index",
                "summary",
                "sidecar"
              ]
            },
            { "$ref": "#/$defs/profileExtensionToken" }
          ]
        },
        "format": {
          "anyOf": [
            { "enum": ["ndjson", "parquet", "duckdb", "arrow", "json"] },
            { "$ref": "#/$defs/profileExtensionToken" }
          ]
        },
        "media_type": { "type": "string", "minLength": 1 },
        "profile": { "type": "string", "minLength": 1 },
        "uri": { "type": "string", "minLength": 1 },
        "integrity": { "$ref": "#/$defs/integrity" },
        "row_count": { "type": "integer", "minimum": 0 },
        "field_catalog_ref": { "type": "string", "minLength": 1 },
        "read_path": { "$ref": "#/$defs/readPath" },
        "protection_enforceable_granularity": { "$ref": "#/$defs/granularity" },
        "format_options": {
          "type": "object",
          "additionalProperties": true
        }
      }
    },
    "readPath": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "range_readable": { "type": "boolean" },
        "partitioned": { "type": "boolean" },
        "sharded": { "type": "boolean" },
        "appendable": { "type": "boolean" },
        "scan_capabilities": {
          "type": "array",
          "items": { "enum": ["sql_scan", "columnar_scan", "predicate_pushdown", "random_access"] },
          "uniqueItems": true
        },
        "read_path_granularity": { "$ref": "#/$defs/granularity" },
        "gateable_unit_granularity": { "$ref": "#/$defs/granularity" },
        "pushdown_withheld": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "sidecar_required": { "type": "boolean" },
        "physical_ordering": { "type": "string", "minLength": 1 },
        "split_strategy": { "type": "string", "minLength": 1 },
        "shard_ids_opaque": { "type": "boolean" }
      }
    },
    "fieldCatalog": {
      "type": "object",
      "additionalProperties": false,
      "required": ["id", "grain", "fields"],
      "properties": {
        "id": { "type": "string", "minLength": 1 },
        "grain": { "type": "string", "minLength": 1 },
        "fields": {
          "type": "array",
          "minItems": 1,
          "items": { "$ref": "#/$defs/field" }
        },
        "withheld_fields": {
          "type": "array",
          "items": { "type": "string", "minLength": 1 },
          "uniqueItems": true
        },
        "withheld_field_count": { "type": "integer", "minimum": 0 }
      }
    },
    "field": {
      "type": "object",
      "additionalProperties": false,
      "required": ["name", "type", "sensitivity"],
      "properties": {
        "name": { "type": "string", "minLength": 1 },
        "type": {
          "enum": [
            "string",
            "integer",
            "number",
            "boolean",
            "date",
            "datetime",
            "object",
            "array",
            "null"
          ]
        },
        "required": { "type": "boolean" },
        "semantic_role": { "type": "string", "minLength": 1 },
        "sensitivity": { "$ref": "#/$defs/sensitivity" },
        "protection_tags": {
          "type": "array",
          "items": { "$ref": "#/$defs/protectionTag" },
          "uniqueItems": true
        },
        "export_action": { "enum": ["allow", "block_export"] },
        "safe_to_profile": { "type": "boolean" }
      },
      "allOf": [
        {
          "$comment": "Machine witness hook for default-deny: unknown fields must be explicitly blocked in portable fixtures.",
          "if": {
            "required": ["sensitivity"],
            "properties": { "sensitivity": { "const": "unknown" } }
          },
          "then": {
            "required": ["export_action"],
            "properties": { "export_action": { "const": "block_export" } }
          }
        }
      ]
    },
    "disclosureControl": {
      "type": "object",
      "additionalProperties": false,
      "required": ["method", "applied"],
      "properties": {
        "method": { "type": "string", "minLength": 1 },
        "min_cell_size": { "type": "integer", "minimum": 2 },
        "applied": { "type": "boolean" },
        "k_applied": { "type": "boolean" },
        "suppression_applied": { "type": "boolean" }
      }
    },
    "integrity": {
      "type": "object",
      "additionalProperties": false,
      "required": ["mode"],
      "properties": {
        "mode": { "enum": ["whole_digest", "shard_digests", "hash_chain_head", "merkle_root"] },
        "algorithm": { "type": "string", "minLength": 1 },
        "value": { "type": "string", "minLength": 1 }
      }
    },
    "granularity": {
      "enum": ["artifact", "shard", "frame", "row_group", "column", "row", "cell"]
    },
    "sensitivity": {
      "enum": ["public", "internal", "controlled", "restricted", "unknown"]
    },
    "protectionTag": {
      "enum": [
        "direct_identifier",
        "quasi_identifier",
        "linkage_key",
        "access_control_metadata",
        "source_structure",
        "measure",
        "freeform_text",
        "opaque_payload",
        "safe_to_profile"
      ]
    }
  }
}
